{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "async": false
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/restore_runtime_context.py\" \"${CLAUDE_PROJECT_DIR}\"",
            "statusMessage": "Restoring harness state...",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/pretool_guard.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/posttool_trace.py\" \"${CLAUDE_PROJECT_DIR}\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/summarize_status.py\" \"${CLAUDE_PROJECT_DIR}\"",
            "statusMessage": "Saving harness state before compaction...",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/summarize_status.py\" \"${CLAUDE_PROJECT_DIR}\"",
            "statusMessage": "Saving harness state...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
